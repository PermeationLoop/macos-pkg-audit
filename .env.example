# PKG Audit Tool — Environment Configuration
#
# Copy this file to .env and fill in your credentials.

# === Required: API Keys ===
# At least one of these is required.

# Anthropic API key (for Claude models — orchestrator, payload-inspector, script-analyzer)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (for GPT models — signature-auditor, binary-inspector)
OPENAI_API_KEY=sk-...

# === Optional: Custom LLM Endpoints ===
# Override the default API endpoints. Useful for:
#   - OpenRouter:        https://openrouter.ai/api/v1/anthropic
#   - Anthropic proxy:   https://your-proxy.example.com
#   - LiteLLM gateway:   https://your-litellm.example.com

# Override Anthropic API endpoint
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Override OpenAI API endpoint
OPENAI_BASE_URL=https://api.openai.com/v1

# === Optional: Telemetry ===
# Disable anonymous usage data collection
# TELEMETRY_ENABLED=false
